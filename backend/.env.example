# =============================================
# Supersonic Music Backend - Environment Variables
# =============================================
# For Railway deployment, set these in the Railway dashboard:
# https://railway.app/project/YOUR_PROJECT > Variables

# Port for the server (Railway sets PORT automatically)
PORT=3001

# Region for YouTube content (default: IN for India)
REGION=IN

# YouTube Data API Key (optional - used for some features like channel details)
# Get your API key from: https://console.cloud.google.com/
YT_KEY=your_youtube_api_key_here

# Node environment
NODE_ENV=production

# Allowed Origins for CORS (comma-separated)
# For Railway + Vercel: https://your-app.vercel.app
# For Railway + Railway frontend: https://your-frontend.up.railway.app
# Leave empty or set to * to allow all origins (not recommended for production)
ALLOWED_ORIGINS=*
